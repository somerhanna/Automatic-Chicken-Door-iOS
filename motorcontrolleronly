                                    HStack(spacing: 15) {
                                        StatusBadge(title: "Motor", value: bleManager.motorStatus, color: .blue)
                                        StatusBadge(title: "Top Limit", value: bleManager.topLimit, color: .orange)
                                        StatusBadge(title: "Bottom Limit", value: bleManager.bottomLimit, color: .orange)
                                    }
                                }
                            }
                            .padding(.horizontal)
                            .padding(.vertical, 10)
                            .background(Color.white.opacity(0.7))
                            .cornerRadius(15)
                        }
                        .padding(.top, 10)
                        
                        // Manual Control Section
                        VStack(spacing: 15) {
                            Text("Manual Control")
                                .font(.title2)
                                .fontWeight(.semibold)
                                .foregroundColor(.brown)
                            
                            HStack(spacing: 15) {
                                // Open Button
                                MotorButton(
                                    title: "OPEN",
                                    icon: "arrow.up.circle.fill",
                                    color: .green,
                                    isEnabled: bleManager.isConnected && bleManager.topLimit != "ACTIVE"
                                ) {
                                    bleManager.sendCommand("forward")
                                }
                                
                                // Stop Button
                                MotorButton(
                                    title: "STOP",
                                    icon: "stop.circle.fill",
                                    color: .red,
                                    isEnabled: bleManager.isConnected
                                ) {
                                    bleManager.sendCommand("stop")
                                }
                                
