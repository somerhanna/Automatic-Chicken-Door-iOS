import SwiftUI
import CoreBluetooth

// MARK: - BLE Manager with Auto-Connect
class BLEManager: NSObject, ObservableObject {
    private var centralManager: CBCentralManager!
    private var peripheral: CBPeripheral?
    private var characteristic: CBCharacteristic?
    
    @Published var isConnected = false
    @Published var connectionStatus = "Searching for ESP32-LED..."
    @Published var lastCommand = ""
    @Published var motorStatus = "IDLE"
    
    // UUIDs must match the ESP32 sketch
    let serviceUUID = CBUUID(string: "4fafc201-1fb5-459e-8fcc-c5c9c331914b")
    let characteristicUUID = CBUUID(string: "beb5483e-36e1-4688-b7f5-ea07361b26a8")
    
    // Auto-reconnect variables
    private var isScanning = false
    private var reconnectAttempts = 0
    private let maxReconnectAttempts = 5
    
    override init() {
        super.init()
        centralManager = CBCentralManager(delegate: self, queue: DispatchQueue.main)
    }
    
    func sendCommand(_ command: String) {
        guard let peripheral = peripheral,
              let characteristic = characteristic,
              isConnected else {
            connectionStatus = "Not connected - auto-reconnecting..."
            return
        }
        
        let data = command.data(using: .utf8)!
        peripheral.writeValue(data, for: characteristic, type: .withResponse)
        lastCommand = command
        connectionStatus = "Sent: \(command)"
        
        // Reset after 2 seconds
        DispatchQueue.main.asyncAfter(deadline: .now() + 2) {
            if self.isConnected {
                self.connectionStatus = "Connected - Ready"
            }
        }
    }
    
    private func startAutoScan() {
        guard !isScanning, centralManager.state == .poweredOn else { return }
        
        isScanning = true
        connectionStatus = "Scanning for ESP32-LED..."
        centralManager.scanForPeripherals(withServices: [serviceUUID], options: [
            CBCentralManagerScanOptionAllowDuplicatesKey: false
        ])
        
        // Stop scanning after 10 seconds and retry if needed
        DispatchQueue.main.asyncAfter(deadline: .now() + 10) { [weak self] in
            self?.stopScanAndRetry()
        }
    }
    
    private func stopScanAndRetry() {
        if centralManager.isScanning {
            centralManager.stopScan()
            isScanning = false
        }
        
        if !isConnected && reconnectAttempts < maxReconnectAttempts {
            reconnectAttempts += 1
            connectionStatus = "Retry \(reconnectAttempts)/\(maxReconnectAttempts)..."
            DispatchQueue.main.asyncAfter(deadline: .now() + 2) { [weak self] in
                self?.startAutoScan()
            }
        } else if !isConnected {
            connectionStatus = "ESP32-LED not found - check power"
        }
    }
    
    private func connectToDevice(_ peripheral: CBPeripheral) {
        self.peripheral = peripheral
        self.peripheral?.delegate = self
        centralManager.stopScan()
        isScanning = false
        centralManager.connect(peripheral, options: nil)
        connectionStatus = "Connecting..."
    }
}

// MARK: - BLE Manager Delegate
extension BLEManager: CBCentralManagerDelegate {
    func centralManagerDidUpdateState(_ central: CBCentralManager) {
        switch central.state {
        case .poweredOn:
            connectionStatus = "Bluetooth on - searching..."
            startAutoScan()
        case .poweredOff:
            isConnected = false
            connectionStatus = "Bluetooth is off - please enable"
            peripheral = nil
            characteristic = nil
        case .unauthorized:
            connectionStatus = "Bluetooth permission denied"
        case .unsupported:
            connectionStatus = "Bluetooth not supported"
        default:
            connectionStatus = "Bluetooth unavailable"
        }
    }
    
    func centralManager(_ central: CBCentralManager, didDiscover peripheral: CBPeripheral, advertisementData: [String : Any], rssi RSSI: NSNumber) {
        if peripheral.name == "ESP32-LED" {
            print("✅ Found ESP32-LED - connecting...")
            connectToDevice(peripheral)
        }
    }
    
    func centralManager(_ central: CBCentralManager, didConnect peripheral: CBPeripheral) {
        isConnected = true
        reconnectAttempts = 0
        connectionStatus = "Connected! Ready"
        print("✅ Connected to ESP32-LED")
        peripheral.discoverServices([serviceUUID])
    }
    
    func centralManager(_ central: CBCentralManager, didFailToConnect peripheral: CBPeripheral, error: Error?) {
        isConnected = false
        connectionStatus = "Connection failed - retrying..."
        print("❌ Failed to connect: \(error?.localizedDescription ?? "unknown")")
        startAutoScan()
    }
    
    func centralManager(_ central: CBCentralManager, didDisconnectPeripheral peripheral: CBPeripheral, error: Error?) {
        isConnected = false
        connectionStatus = "Disconnected - reconnecting..."
        print("❌ Disconnected - auto-reconnecting")
        self.peripheral = nil
        self.characteristic = nil
        startAutoScan()
    }
}

extension BLEManager: CBPeripheralDelegate {
    func peripheral(_ peripheral: CBPeripheral, didDiscoverServices error: Error?) {
        if let error = error {
            print("Service discovery error: \(error)")
            return
        }
        
        if let services = peripheral.services {
            for service in services {
                if service.uuid == serviceUUID {
                    peripheral.discoverCharacteristics([characteristicUUID], for: service)
                }
            }
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didDiscoverCharacteristicsFor service: CBService, error: Error?) {
        if let error = error {
            print("Characteristic discovery error: \(error)")
            return
        }
        
        if let characteristics = service.characteristics {
            for characteristic in characteristics {
                if characteristic.uuid == characteristicUUID {
                    self.characteristic = characteristic
                    connectionStatus = "Ready to control motor"
                    print("✅ Ready to control motor")
                    peripheral.setNotifyValue(true, for: characteristic)
                }
            }
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didWriteValueFor characteristic: CBCharacteristic, error: Error?) {
        if let error = error {
            print("Write error: \(error)")
            connectionStatus = "Command failed - retrying..."
        } else {
            print("✅ Command sent successfully")
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didUpdateValueFor characteristic: CBCharacteristic, error: Error?) {
        if let error = error {
            print("Read error: \(error)")
            return
        }
        
        if let value = characteristic.value {
            let statusString = String(data: value, encoding: .utf8) ?? ""
            if statusString.hasPrefix("STATUS:") {
                motorStatus = String(statusString.dropFirst(7))
                print("Motor status: \(motorStatus)")
            }
        }
    }
}

// MARK: - Main View
struct ContentView: View {
    @StateObject private var bleManager = BLEManager()
    @State private var showingAlert = false
    @State private var alertMessage = ""
    
    var body: some View {
        ZStack {
            // Background gradient
            LinearGradient(
                colors: [
                    Color.blue.opacity(0.3),
                    Color.green.opacity(0.2),
                    Color.white
                ],
                startPoint: .topLeading,
                endPoint: .bottomTrailing
            )
            .ignoresSafeArea()
            
            // Main Content
            VStack(spacing: 25) {
                // Header
                VStack(spacing: 10) {
                    Text("🐔 Chicken Door")
                        .font(.system(size: 45, weight: .bold))
                        .foregroundColor(.blue)
                    
                    Text("Motor Controller")
                        .font(.title3)
                        .foregroundColor(.brown)
                    
                    // Connection Status
                    VStack(spacing: 8) {
                        HStack {
                            Circle()
                                .fill(bleManager.isConnected ? Color.green : Color.yellow)
                                .frame(width: 12, height: 12)
                            Text(bleManager.connectionStatus)
                                .font(.caption)
                                .foregroundColor(.gray)
                        }
                        
                        // Motor Status
                        if bleManager.isConnected {
                            Text("Motor: \(bleManager.motorStatus)")
                                .font(.caption)
                                .fontWeight(.semibold)
                                .foregroundColor(.blue)
                                .padding(.horizontal, 12)
                                .padding(.vertical, 4)
                                .background(Color.blue.opacity(0.1))
                                .cornerRadius(12)
                        }
                    }
                    .padding(.horizontal)
                    .padding(.vertical, 8)
                    .background(Color.white.opacity(0.5))
                    .cornerRadius(20)
                }
                .padding(.top, 20)
                
                Spacer()
                
                // Motor Control Buttons
                VStack(spacing: 25) {
                    Text("Motor Control")
                        .font(.title2)
                        .fontWeight(.semibold)
                        .foregroundColor(.brown)
                    
                    // 3 Main Motor Buttons
                    VStack(spacing: 20) {
                        // Start Button
                        MotorButton(
                            title: "START",
                            icon: "play.fill",
                            color: .green,
                            isEnabled: bleManager.isConnected
                        ) {
                            bleManager.sendCommand("start")
                        }
                        
                        // Stop Button
                        MotorButton(
                            title: "STOP",
                            icon: "stop.fill",
                            color: .red,
                            isEnabled: bleManager.isConnected
                        ) {
                            bleManager.sendCommand("stop")
                        }
                        
                        // Reverse Button
                        MotorButton(
                            title: "REVERSE",
                            icon: "arrow.left.arrow.right",
                            color: .blue,
                            isEnabled: bleManager.isConnected && bleManager.motorStatus != "IDLE"
                        ) {
                            bleManager.sendCommand("reverse")
                        }
                    }
                    .padding(.horizontal)
                }
                
                Spacer()
                
                // Last command display
                if !bleManager.lastCommand.isEmpty {
                    Text("Last: \(bleManager.lastCommand)")
                        .font(.caption)
                        .foregroundColor(.gray)
                        .padding(.bottom, 20)
                }
            }
            .padding()
        }
        .alert(isPresented: $showingAlert) {
            Alert(title: Text("Connection Status"), message: Text(alertMessage), dismissButton: .default(Text("OK")))
        }
    }
}

// MARK: - Motor Button Style
struct MotorButton: View {
    let title: String
    let icon: String
    let color: Color
    let isEnabled: Bool
    let action: () -> Void
    
    var body: some View {
        Button(action: action) {
            HStack {
                Image(systemName: icon)
                    .font(.system(size: 30))
                Text(title)
                    .font(.title2)
                    .fontWeight(.bold)
            }
            .foregroundColor(.white)
            .padding(.vertical, 20)
            .frame(maxWidth: .infinity)
            .background(
                LinearGradient(
                    colors: isEnabled ? [color, color.opacity(0.7)] : [Color.gray, Color.gray.opacity(0.7)],
                    startPoint: .top,
                    endPoint: .bottom
                )
            )
            .cornerRadius(20)
            .shadow(color: isEnabled ? color.opacity(0.3) : Color.clear, radius: 5, x: 0, y: 5)
        }
        .disabled(!isEnabled)
    }
}

