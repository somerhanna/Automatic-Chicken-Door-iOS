import SwiftUI
import CoreBluetooth

// MARK: - Schedule Model
struct DoorSchedule: Codable {
    var openTime: Date
    var closeTime: Date
    var isEnabled: Bool
    
    var openHour: Int {
        Calendar.current.component(.hour, from: openTime)
    }
    var openMinute: Int {
        Calendar.current.component(.minute, from: openTime)
    }
    var closeHour: Int {
        Calendar.current.component(.hour, from: closeTime)
    }
    var closeMinute: Int {
        Calendar.current.component(.minute, from: closeTime)
    }
    
    func toString() -> String {
        return "\(openHour),\(openMinute),\(closeHour),\(closeMinute),\(isEnabled ? 1 : 0)"
    }
}

// MARK: - BLE Manager
class BLEManager: NSObject, ObservableObject {
    private var centralManager: CBCentralManager!
    private var peripheral: CBPeripheral?
    private var motorCharacteristic: CBCharacteristic?
    private var scheduleCharacteristic: CBCharacteristic?
    
    @Published var isConnected = false
    @Published var connectionStatus = "Scanning for Chicken-Door..."
    @Published var lastCommand = ""
    @Published var motorStatus = "IDLE"
    @Published var topLimit = "OK"
    @Published var bottomLimit = "OK"
    @Published var doorSchedule = DoorSchedule(
        openTime: Calendar.current.date(from: DateComponents(hour: 6, minute: 0)) ?? Date(),
        closeTime: Calendar.current.date(from: DateComponents(hour: 18, minute: 0)) ?? Date(),
        isEnabled: true
    )
    
    // BLE UUIDs
    let serviceUUID = CBUUID(string: "4fafc201-1fb5-459e-8fcc-c5c9c331914b")
    let motorUUID = CBUUID(string: "beb5483e-36e1-4688-b7f5-ea07361b26a8")
    let scheduleUUID = CBUUID(string: "2a5c6d8e-1fb5-459e-8fcc-c5c9c331914b")
    
    // Auto-reconnect variables
    private var isScanning = false
    private var reconnectAttempts = 0
    private let maxReconnectAttempts = 5
    
    override init() {
        super.init()
        centralManager = CBCentralManager(delegate: self, queue: DispatchQueue.main)
    }
    
    func sendCommand(_ command: String) {
        guard let peripheral = peripheral,
              let characteristic = motorCharacteristic,
              isConnected else {
            connectionStatus = "Not connected - reconnecting..."
            return
        }
        
        let data = command.data(using: .utf8)!
        peripheral.writeValue(data, for: characteristic, type: .withResponse)
        lastCommand = command
        connectionStatus = "Sent: \(command)"
        
        // Reset status message after 2 seconds
        DispatchQueue.main.asyncAfter(deadline: .now() + 2) {
            if self.isConnected {
                self.connectionStatus = "Connected ✓"
            }
        }
    }
    
    func sendSchedule() {
        guard let peripheral = peripheral,
              let characteristic = scheduleCharacteristic,
              isConnected else {
            return
        }
        
        let scheduleString = doorSchedule.toString()
        let data = scheduleString.data(using: .utf8)!
        peripheral.writeValue(data, for: characteristic, type: .withResponse)
        connectionStatus = "Schedule saved!"
        print("📤 Schedule sent: \(scheduleString)")
        
        DispatchQueue.main.asyncAfter(deadline: .now() + 2) {
            if self.isConnected {
                self.connectionStatus = "Connected ✓"
            }
        }
    }
    
    private func startAutoScan() {
        guard !isScanning, centralManager.state == .poweredOn else { return }
        
        isScanning = true
        connectionStatus = "Scanning for Chicken-Door..."
        centralManager.scanForPeripherals(withServices: [serviceUUID], options: [
            CBCentralManagerScanOptionAllowDuplicatesKey: false
        ])
        
        // Stop scanning after 10 seconds and retry
        DispatchQueue.main.asyncAfter(deadline: .now() + 10) { [weak self] in
            self?.stopScanAndRetry()
        }
    }
    
    private func stopScanAndRetry() {
        if centralManager.isScanning {
            centralManager.stopScan()
            isScanning = false
        }
        
        if !isConnected && reconnectAttempts < maxReconnectAttempts {
            reconnectAttempts += 1
            connectionStatus = "Retry \(reconnectAttempts)/\(maxReconnectAttempts)..."
            DispatchQueue.main.asyncAfter(deadline: .now() + 2) { [weak self] in
                self?.startAutoScan()
            }
        } else if !isConnected {
            connectionStatus = "Not found - check device"
        }
    }
    
    private func connectToDevice(_ peripheral: CBPeripheral) {
        self.peripheral = peripheral
        self.peripheral?.delegate = self
        centralManager.stopScan()
        isScanning = false
        centralManager.connect(peripheral, options: nil)
        connectionStatus = "Connecting..."
    }
}

// MARK: - BLE Manager Delegate
extension BLEManager: CBCentralManagerDelegate {
    func centralManagerDidUpdateState(_ central: CBCentralManager) {
        switch central.state {
        case .poweredOn:
            connectionStatus = "Bluetooth ON - searching..."
            startAutoScan()
        case .poweredOff:
            isConnected = false
            connectionStatus = "Bluetooth OFF - please enable"
            peripheral = nil
            motorCharacteristic = nil
            scheduleCharacteristic = nil
        case .unauthorized:
            connectionStatus = "Bluetooth permission denied"
        case .unsupported:
            connectionStatus = "Bluetooth not supported"
        default:
            connectionStatus = "Bluetooth unavailable"
        }
    }
    
    func centralManager(_ central: CBCentralManager, didDiscover peripheral: CBPeripheral, advertisementData: [String : Any], rssi RSSI: NSNumber) {
        if peripheral.name == "Chicken-Door" {
            print("✅ Found Chicken-Door - connecting...")
            connectToDevice(peripheral)
        }
    }
    
    func centralManager(_ central: CBCentralManager, didConnect peripheral: CBPeripheral) {
        isConnected = true
        reconnectAttempts = 0
        connectionStatus = "Connected ✓"
        print("✅ Connected to Chicken-Door")
        peripheral.discoverServices([serviceUUID])
    }
    
    func centralManager(_ central: CBCentralManager, didFailToConnect peripheral: CBPeripheral, error: Error?) {
        isConnected = false
        connectionStatus = "Connection failed - retrying..."
        print("❌ Failed to connect: \(error?.localizedDescription ?? "unknown")")
        startAutoScan()
    }
    
    func centralManager(_ central: CBCentralManager, didDisconnectPeripheral peripheral: CBPeripheral, error: Error?) {
        isConnected = false
        connectionStatus = "Disconnected - reconnecting..."
        print("❌ Disconnected - auto-reconnecting")
        self.peripheral = nil
        self.motorCharacteristic = nil
        self.scheduleCharacteristic = nil
        startAutoScan()
    }
}

extension BLEManager: CBPeripheralDelegate {
    func peripheral(_ peripheral: CBPeripheral, didDiscoverServices error: Error?) {
        if let error = error {
            print("Service discovery error: \(error)")
            return
        }
        
        if let services = peripheral.services {
            for service in services {
                if service.uuid == serviceUUID {
                    peripheral.discoverCharacteristics([motorUUID, scheduleUUID], for: service)
                }
            }
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didDiscoverCharacteristicsFor service: CBService, error: Error?) {
        if let error = error {
            print("Characteristic discovery error: \(error)")
            return
        }
        
        if let characteristics = service.characteristics {
            for characteristic in characteristics {
                if characteristic.uuid == motorUUID {
                    self.motorCharacteristic = characteristic
                    peripheral.setNotifyValue(true, for: characteristic)
                    print("✅ Motor control ready")
                }
                if characteristic.uuid == scheduleUUID {
                    self.scheduleCharacteristic = characteristic
                    peripheral.setNotifyValue(true, for: characteristic)
                    peripheral.readValue(for: characteristic)
                    print("✅ Schedule control ready")
                }
            }
            connectionStatus = "Ready to control 🐔"
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didWriteValueFor characteristic: CBCharacteristic, error: Error?) {
        if let error = error {
            print("Write error: \(error)")
            connectionStatus = "Command failed"
        } else {
            print("✅ Command sent successfully")
        }
    }
    
    func peripheral(_ peripheral: CBPeripheral, didUpdateValueFor characteristic: CBCharacteristic, error: Error?) {
        if let error = error {
            print("Read error: \(error)")
            return
        }
        
        if let value = characteristic.value {
            let stringValue = String(data: value, encoding: .utf8) ?? ""
            
            if characteristic.uuid == motorUUID {
                // Parse status: "STATUS:IDLE,TOP:OK,BOTTOM:OK"
                let parts = stringValue.split(separator: ",")
                for part in parts {
                    if part.hasPrefix("STATUS:") {
                        motorStatus = String(part.dropFirst(7))
                    } else if part.hasPrefix("TOP:") {
                        topLimit = String(part.dropFirst(4))
                    } else if part.hasPrefix("BOTTOM:") {
                        bottomLimit = String(part.dropFirst(7))
                    }
                }
                print("📊 Status: \(motorStatus) | Top: \(topLimit) | Bottom: \(bottomLimit)")
            }
            else if characteristic.uuid == scheduleUUID {
                // Parse schedule: "6,0,18,0,1"
                let components = stringValue.split(separator: ",")
                if components.count == 5 {
                    if let openHour = Int(components[0]),
                       let openMinute = Int(components[1]),
                       let closeHour = Int(components[2]),
                       let closeMinute = Int(components[3]),
                       let enabled = Int(components[4]) {
                        
                        var calendar = Calendar.current
                        let now = Date()
                        var openComponents = calendar.dateComponents([.year, .month, .day], from: now)
                        openComponents.hour = openHour
                        openComponents.minute = openMinute
                        
                        var closeComponents = calendar.dateComponents([.year, .month, .day], from: now)
                        closeComponents.hour = closeHour
                        closeComponents.minute = closeMinute
                        
                        DispatchQueue.main.async {
                            self.doorSchedule.openTime = calendar.date(from: openComponents) ?? Date()
                            self.doorSchedule.closeTime = calendar.date(from: closeComponents) ?? Date()
                            self.doorSchedule.isEnabled = enabled == 1
                        }
                        print("📅 Schedule loaded: Open at \(openHour):\(openMinute), Close at \(closeHour):\(closeMinute)")
                    }
                }
            }
        }
    }
}

// MARK: - Modal Time Picker (Forced Confirmation)
struct ModalTimePicker: View {
    @Binding var currentTime: Date
    let title: String
    let icon: String
    let color: Color
    let onSave: (Date) -> Void
    
    @Environment(\.dismiss) var dismiss
    @State private var tempTime: Date
    
    init(currentTime: Binding<Date>, title: String, icon: String, color: Color, onSave: @escaping (Date) -> Void) {
        self._currentTime = currentTime
        self.title = title
        self.icon = icon
        self.color = color
        self.onSave = onSave
        self._tempTime = State(initialValue: currentTime.wrappedValue)
    }
    
    var body: some View {
        NavigationView {
            ZStack {
                // Background
                Color(.systemGroupedBackground)
                    .ignoresSafeArea()
                
                VStack(spacing: 30) {
                    // Icon and Title
                    VStack(spacing: 15) {
                        Image(systemName: icon)
                            .font(.system(size: 60))
                            .foregroundColor(color)
                        
                        Text(title)
                            .font(.title2)
                            .fontWeight(.semibold)
                            .foregroundColor(.brown)
                    }
                    .padding(.top, 40)
                    
                    // Time Picker
                    DatePicker("", selection: $tempTime, displayedComponents: .hourAndMinute)
                        .datePickerStyle(.wheel)
                        .labelsHidden()
                        .frame(height: 200)
                        .environment(\.locale, Locale(identifier: "en_US"))
                    
                    Spacer()
                }
                .padding()
            }
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarLeading) {
                    Button("Cancel") {
                        dismiss()
                    }
                    .foregroundColor(.red)
                }
                
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button("Save") {
                        onSave(tempTime)
                        dismiss()
                    }
                    .fontWeight(.semibold)
                    .foregroundColor(.blue)
                }
            }
        }
        .presentationDetents([.height(400)])
        .presentationDragIndicator(.visible)
    }
}

