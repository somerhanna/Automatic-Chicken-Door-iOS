                        }
                        .padding(.vertical)
                        .background(Color.white.opacity(0.5))
                        .cornerRadius(20)
                        .padding(.horizontal)
                        
                        // Automatic Schedule Section
                        VStack(spacing: 15) {
                            HStack {
                                VStack(alignment: .leading, spacing: 4) {
                                    Text("Automatic Schedule")
                                        .font(.title2)
                                        .fontWeight(.semibold)
                                        .foregroundColor(.brown)
                                    
                                    Text("Door opens/closes automatically")
                                        .font(.caption)
                                        .foregroundColor(.gray)
                                }
                                
                                Spacer()
                                
                                Toggle("", isOn: $bleManager.doorSchedule.isEnabled)
                                    .onChange(of: bleManager.doorSchedule.isEnabled) { oldValue, newValue in
                                        bleManager.sendSchedule()
                                    }
                                    .labelsHidden()
                            }
                            .padding(.horizontal)
                            
                            if bleManager.doorSchedule.isEnabled {
                                VStack(spacing: 15) {
                                    // Open Time Row - Tappable
                                    TimeDisplayRow(
                                        title: "Open Time",
                                        icon: "sunrise.fill",
                                        color: .orange,
                                        time: bleManager.doorSchedule.openTime
                                    ) {
                                        showingOpenPicker = true
                                    }
                                    
                                    // Close Time Row - Tappable
                                    TimeDisplayRow(
                                        title: "Close Time",
                                        icon: "sunset.fill",
                                        color: .purple,
                                        time: bleManager.doorSchedule.closeTime
                                    ) {
                                        showingClosePicker = true
                                    }
                                }
                                .padding(.horizontal)
                            } else {
                                Text("Schedule disabled - use manual controls")
                                    .font(.caption)
                                    .foregroundColor(.gray)
                                    .padding(.vertical, 10)
                            }
                        }
                        .padding(.vertical)
                        .background(Color.white.opacity(0.5))
                        .cornerRadius(20)
                        .padding(.horizontal)
                        
                        // Last Command Display
                        if !bleManager.lastCommand.isEmpty {
                            Text("Last command: \(bleManager.lastCommand)")
                                .font(.caption)
                                .foregroundColor(.gray)
                                .padding(.bottom, 10)
                        }
                    }
                }
            }
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button(action: {
                        bleManager.sendCommand("status")
                    }) {
                        Image(systemName: "arrow.clockwise")
                            .foregroundColor(bleManager.isConnected ? .blue : .gray)
                    }
                    .disabled(!bleManager.isConnected)
                }
            }
        }
        .sheet(isPresented: $showingOpenPicker) {
            ModalTimePicker(
                currentTime: $bleManager.doorSchedule.openTime,
                title: "Set Opening Time",
                icon: "sunrise.fill",
                color: .orange
            ) { newTime in
                bleManager.doorSchedule.openTime = newTime
                bleManager.sendSchedule()
            }
        }
        .sheet(isPresented: $showingClosePicker) {
            ModalTimePicker(
                currentTime: $bleManager.doorSchedule.closeTime,
                title: "Set Closing Time",
                icon: "sunset.fill",
                color: .purple
            ) { newTime in
                bleManager.doorSchedule.closeTime = newTime
                bleManager.sendSchedule()
            }
        }
    }
}

// MARK: - Supporting Views
struct StatusBadge: View {
    let title: String
    let value: String
    let color: Color
    
    var body: some View {
        VStack(spacing: 4) {
            Text(title)
                .font(.caption2)
                .foregroundColor(.gray)
            Text(value)
                .font(.caption)
                .fontWeight(.semibold)
                .foregroundColor(value == "ACTIVE" ? .red : color)
        }
        .padding(.horizontal, 8)
        .padding(.vertical, 4)
        .background(color.opacity(0.1))
        .cornerRadius(8)
    }
}

struct MotorButton: View {
    let title: String
    let icon: String
    let color: Color
    let isEnabled: Bool
    let action: () -> Void
    
    var body: some View {
        Button(action: action) {
            VStack(spacing: 8) {
                Image(systemName: icon)
                    .font(.system(size: 35))
                Text(title)
                    .font(.headline)
                    .fontWeight(.bold)
            }
            .foregroundColor(.white)
            .padding(.vertical, 15)
            .frame(maxWidth: .infinity)
            .background(
                LinearGradient(
                    colors: isEnabled ? [color, color.opacity(0.7)] : [Color.gray, Color.gray.opacity(0.6)],
                    startPoint: .top,
                    endPoint: .bottom
                )
            )
            .cornerRadius(15)
            .shadow(color: isEnabled ? color.opacity(0.3) : Color.clear, radius: 5, x: 0, y: 5)
        }
        .disabled(!isEnabled)
    }
}

